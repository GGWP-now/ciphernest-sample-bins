<Window x:Class="TaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskManager"
        Title="WPF Task Manager" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <DockPanel LastChildFill="True" Margin="8">
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button Command="{Binding RefreshCommand}" Content="Refresh" Width="80" />
            <Separator />
            <Label Content="Filter:" VerticalAlignment="Center" />
            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Width="200" VerticalAlignment="Center" />
            <Separator />
            <Button Command="{Binding KillCommand}" Content="End Task" Width="80" />
        </ToolBar>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Process list -->
        <DataGrid ItemsSource="{Binding Processes}"
                  SelectedItem="{Binding SelectedProcess}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F0F0F0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Process Name"   Binding="{Binding Name}"      Width="2*" />
                <DataGridTextColumn Header="PID"            Binding="{Binding Id}"        Width="80" />
                <DataGridTextColumn Header="Working Set"    Binding="{Binding WorkingSet, StringFormat=N0}" Width="120" />
                <DataGridTextColumn Header="CPU Time"       Binding="{Binding CpuTime}"   Width="120" />
                <DataGridTextColumn Header="Responding"     Binding="{Binding Responding}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
