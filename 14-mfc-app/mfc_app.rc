#include "resource.h"
#include <afxres.h>

IDD_MAIN_DLG DIALOGEX 0, 0, 320, 200
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "MFC License Validator"
FONT 9, "Segoe UI", 0, 0, 0x1
BEGIN
    LTEXT           "Enter License Key:",IDC_STATIC,20,20,120,12
    EDITTEXT        IDC_LICENSE_INPUT,20,36,280,14,ES_AUTOHSCROLL
    PUSHBUTTON      "&Validate",IDC_VALIDATE_BTN,120,70,80,24
    LTEXT           "Enter a key and click Validate.",IDC_RESULT_TEXT,20,110,280,60
END
